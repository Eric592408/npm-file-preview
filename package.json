{
  "name": "@eric_bs/universal-file-preview",
  "version": "1.0.0-beta.1",
  "description": "A universal file preview library for web applications, supporting PDF, images, Office documents and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs",
      "types": "./dist/vue.d.ts"
    },
    "./web-component": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:css && npm run build:lib && npm run build:types",
    "build:lib": "vite build",
    "build:css": "vite build --config vite.config.css.ts",
    "build:types": "vue-tsc --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "file-preview",
    "document-viewer",
    "pdf-viewer",
    "office-preview",
    "vue",
    "web-component",
    "typescript"
  ],
  "author": "wf.j",
  "license": "MIT",
  "dependencies": {
    "pdfjs-dist": "^3.11.174",
    "marked": "^9.1.0",
    "docx-preview": "^0.1.20",
    "pptx-preview": "^1.0.5",
    "xlsx": "^0.18.5"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/compiler-sfc": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Eric592408/npm-file-preview"
  }
}
